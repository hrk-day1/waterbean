PORT=4000
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=../sa.json

# Gemini LLM
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=1.0
LLM_TIMEOUT_MS=30000
