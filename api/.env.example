PORT=4000
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=../sa.json

# Gemini LLM
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=1.0
LLM_TIMEOUT_MS=30000
# Optional: max chars logged per block when JSON.parse/Zod fails (default 65536)
# LLM_JSON_LOG_CHARS=200000

# TC Merge (LLM)
# 체크리스트 청크 크기, 기본 20개
LLM_MERGE_CHUNK_SIZE=20
# TC Generator (LLM)
# LLM은 응답 JSON에서 f/ev/ow(st/ac) 축약 키를 생략할 수 있음; 서버가 체크리스트 tr·ri·기본값으로 병합
# 체크리스트 청크 크기, 기본 5개
LLM_GEN_CHUNK_SIZE=5
# Plan (LLM)
# 시트 행 청크 크기, 기본 10행
LLM_PLAN_CHUNK_SIZE=10
# Plan 청크 병렬 호출 수 (1~8, 기본 3)
LLM_PLAN_CONCURRENCY=3
# Orchestrator 배치 크기 (checklist를 N건씩 슬라이스하여 generator→evaluator 순차 실행, 기본 20)
LLM_GEN_BATCH_SIZE=10

# 스펙 리스크 high 행의 Requirement_ID당 TC 상한 기본값 (API highRiskMaxTcPerRequirement 미지정 시)
# PIPELINE_HIGH_RISK_MAX_TC_PER_REQUIREMENT=6

# 도메인 최소 세트 보완 TC 부착 (API body domainMinSetFill 미지정 시). round_robin | representative | off
# PIPELINE_DOMAIN_MINSET_FILL=round_robin

# D-Evaluator 게이트 (API evalSpecGrounding / evalTraceability 미지정 시). off | warn | block (기본 warn)
# PIPELINE_EVAL_SPEC_GROUNDING=warn
# PIPELINE_EVAL_TRACEABILITY=warn

# Plan 완료·Generator 배치 입출력 JSON 저장 (비우면 비활성). 상대 경로는 프로세스 cwd 기준
# 완료 시 {dir}/{pipelineId}/artifacts/pipeline-result.json 에 최종 결과(통계·Evaluator 이슈)도 기록
# PIPELINE_DEBUG_DIR=.pipeline-debug