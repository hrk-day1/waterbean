{
  "name": "waterbean",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "web",
    "waterbean",
    "api"
  ],
  "scripts": {
    "dev": "run-p dev:api dev:clients",
    "dev:clients": "wait-on http-get://127.0.0.1:4000/health -t 120000 && run-p dev:web dev:waterbean",
    "dev:web": "npm run dev -w web",
    "dev:waterbean": "npm run dev -w waterbean",
    "dev:api": "npm run dev -w api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:eslint": "eslint api/src waterbean web",
    "lint:fix": "eslint api/src waterbean web --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript-eslint": "^8.58.0",
    "wait-on": "^8.0.3"
  }
}
